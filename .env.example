# Database
POSTGRES_USER=deloitte
POSTGRES_PASSWORD=deloitte_dev
POSTGRES_DB=search_engine

# Driver User Password Host Port Database
DATABASE_URL=postgresql+asyncpg://deloitte:deloitte_dev@db:5432/search_engine

# Embedding service
# Docker local embedding: http://embedding:8001/embed
# External hosted embedding (for example Colab): https://<your-host>/embed
EMBEDDING_API_URL=http://embedding:8001/embed

# Cohere
COHERE_API_KEY=your_cohere_api_key_here

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Backend
BACKEND_URL=http://localhost:8000

# Gotenberg (document-to-PDF conversion; set automatically in Docker)
GOTENBERG_URL=http://localhost:3001
