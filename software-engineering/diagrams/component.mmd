graph TB
    subgraph Frontend Layer
        UI[Search Interface<br/>Next.js + TypeScript]
        Filter[Filter Panel<br/>Component]
        Results[Results Display<br/>Component]
        Tips[Search Tips<br/>Component]
    end

    subgraph API Layer
        API[FastAPI<br/>REST API Server]
        Auth[Authentication<br/>JWT + RBAC]
    end

    subgraph Processing Layer
        InputVal[Input Validator<br/>and Content Filter]
        EmbedClient[Embedding Client<br/>HTTP to External Model]
        Reranker[Reranker<br/>Cohere Rerank v3.5]
        Ranker[Ranking Service<br/>RRF Merge + Re-rank]
    end

    subgraph Data Layer
        UnifiedDB[(PostgreSQL 16<br/>pgvector + ParadeDB<br/>Hybrid Search)]
        Ingestion[Document Ingestion<br/>Pipeline]
        DocParser[Document Parser<br/>Docling]
    end

    subgraph External Services
        EmbedModel[Embedding Model<br/>Qwen3-Embedding-0.6B<br/>Google Colab + ngrok]
        CohereAPI[Cohere Rerank v3.5<br/>API]
        DocSource[Document Sources<br/>PDFs, DOCX, PPTX]
    end

    UI --> API
    Filter --> API
    Results --> API
    Tips --> API
    API --> Auth
    API --> InputVal
    InputVal --> EmbedClient
    EmbedClient --> EmbedModel
    EmbedClient --> Ranker
    Ranker --> UnifiedDB
    Ranker --> Reranker
    Reranker --> CohereAPI
    Ingestion --> UnifiedDB
    Ingestion --> EmbedModel
    Ingestion --> DocParser
    DocSource --> DocParser
